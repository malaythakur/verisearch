# =============================================================================
# Agentic Research Search Engine - Local Development Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentic_research
POSTGRES_USER=agentic
POSTGRES_PASSWORD=agentic_dev
DATABASE_URL=postgresql://agentic:agentic_dev@localhost:5432/agentic_research

# --- OpenSearch ---
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_URL=http://localhost:9200

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Kafka (Redpanda) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
SCHEMA_REGISTRY_URL=http://localhost:8081

# --- MinIO (S3-compatible object store) ---
MINIO_ENDPOINT=localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=agentic-research-docs
MINIO_USE_SSL=false

# S3-compatible access (used by application code)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=agentic-research-docs

# --- AI/ML Providers ---
# Set these to enable real AI features (leave empty for mock/fallback mode)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# --- Application ---
APP_ENV=dev
LOG_LEVEL=INFO
