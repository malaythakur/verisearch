  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["slo", "performance", "agentic-research"],
  "templating": {
    "list": [
      {
        "name": "tenant_id",
        "type": "query",
        "query": "label_values(http_requests_total, tenant_id)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": {
    "from": "now-6h",
