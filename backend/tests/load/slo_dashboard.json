    {
      "title": "Error Budget Burn Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_requests_total{status=~\"5..\"}[1h])) / sum(rate(http_requests_total[1h])))",
          "legendFormat": "Availability",
          "refId": "A"
        },
        {
          "expr": "0.999",
          "legendFormat": "SLO Target (99.9%)",
          "refId": "B"
        }
      ]
    }
