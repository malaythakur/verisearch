      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ingest_pipeline_duration_seconds_bucket[1h])) by (le)) / 60",
